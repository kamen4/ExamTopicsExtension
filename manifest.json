{
  "manifest_version": 3,
  "name": "ExamTopics Navigator",
  "version": "1.0.0",
  "description": "Navigate between questions and topics on ExamTopics easily",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://www.examtopics.com/*",
    "https://www.google.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.examtopics.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "ExamTopics Navigator",
    "default_icon": "icons/icon.png"
  }
}
